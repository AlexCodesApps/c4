export function w $foo () {
@start
%.r0 =w copy 10
ret %.r0
}
export function l $forward_ref (l %.pa, ) {
@start
%a =l alloc8 8
storel %.pa, %a
%.r0 =l loadl %a
ret %.r0
}
export function w $main (w %.pa, l %.pb, ) {
@start
%a =l alloc4 4
storew %.pa, %a
%b =l alloc8 8
storel %.pb, %b
%c =l alloc4 4
%.r0 =l copy %a
%.r2 =l loadl %b
%.r1 =w loadw %.r2
storew %.r1, %.r0
%.r3 =l copy %c
%.r5 =l copy %a
%.r4 =w loadw %.r5
storew %.r4, %.r3
%.r7 =w loadw %c
ret %.r7
}
